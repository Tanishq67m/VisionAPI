{
  "name": "vision-screenshot-api",
  "version": "1.0.0",
  "description": "Vision-optimized screenshot API for AI agents — clean captures for LLM vision models",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "capture": "tsx src/cli.ts",
    "mcp": "tsx src/mcp-server.ts",
    "mcp:build": "tsc && node dist/mcp-server.js",
    "typecheck": "tsc --noEmit",
    "inspector": "npx @modelcontextprotocol/inspector tsx src/mcp-server.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@supabase/supabase-js": "^2.101.1",
    "dotenv": "^17.4.0",
    "playwright": "^1.44.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "sharp": "^0.34.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/sharp": "^0.31.1",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0"
  }
}
